#!/bin/bash

YEAR=$(date +%Y)
MONTH=$(date +%m)
DAY=$(date +%d)
JOB_DATE_LONG=$(date +%Y%m%d.%H.%M.%S)
FULLHOST=$(hostname --fqdn)
LOGDIR="/var/log/pcp/pmlogger/gautschi/$YEAR/$MONTH/$FULLHOST/$YEAR-$MONTH-$DAY"
PMLOGGER_EPILOG=yes
pmlogger -U pcp -c /etc/pcp/pmlogger/pmlogger-supremm.config -s 1 -l /tmp/job-$SLURM_JOB_ID-end-${JOB_DATE_LONG}.log $LOGDIR/job-$SLURM_JOB_ID-end-$JOB_DATE_LONG &>/dev/null &
sleep 1
