{
  "name": "purdue-af-interface-controls",
  "displayName": "Purdue AF Interface Controls",
  "description": "Status bar buttons to switch to JupyterLab and open JupyterHub shutdown page.",
  "version": "0.1.0",
  "publisher": "purdueaf",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "configuration": {
      "title": "Purdue AF",
      "properties": {
        "purdueaf.jupyterLabPath": {
          "type": "string",
          "default": "/lab/tree",
          "description": "Path to open when switching to JupyterLab."
        },
        "purdueaf.shutdownPath": {
          "type": "string",
          "default": "/hub/home",
          "description": "Path to open when shutting down the server."
        }
      }
    },
    "commands": [
      {
        "command": "purdueaf.switchToJupyterLab",
        "title": "Purdue AF: Switch to JupyterLab"
      },
      {
        "command": "purdueaf.openShutdownPage",
        "title": "Purdue AF: Shut Down (open JupyterHub home)"
      }
    ]
  }
}
