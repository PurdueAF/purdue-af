{
  "name": "purdue-af-interface-controls",
  "displayName": "Purdue AF Interface Controls",
  "description": "Status bar buttons to switch to JupyterLab and open JupyterHub shutdown page.",
  "version": "0.1.0",
  "publisher": "purdueaf",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "configuration": {
      "title": "Purdue AF",
      "properties": {
        "purdueaf.jupyterLabPath": {
          "type": "string",
          "default": "/lab/tree",
          "description": "Path to open when switching to JupyterLab."
        },
        "purdueaf.shutdownApiPath": {
          "type": "string",
          "default": "/api/shutdown",
          "description": "Jupyter Server shutdown API path."
        },
        "purdueaf.hubHomePath": {
          "type": "string",
          "default": "/hub/home",
          "description": "JupyterHub home path shown after shutdown."
        },
        "purdueaf.servicePrefix": {
          "type": "string",
          "default": "",
          "description": "JupyterHub service prefix, e.g. /user/username/"
        },
        "purdueaf.hubOrigin": {
          "type": "string",
          "default": "",
          "description": "Optional absolute Hub origin, e.g. https://cms.geddes.rcac.purdue.edu"
        }
      }
    },
    "commands": [
      {
        "command": "purdueaf.switchToJupyterLab",
        "title": "Purdue AF: Switch to JupyterLab"
      },
      {
        "command": "purdueaf.openShutdownPage",
        "title": "Purdue AF: Shut Down session"
      }
    ]
  }
}
